{
  "name": "esquire-tech",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3035",
    "build": "prisma generate && next build",
    "start": "next start -p 3035",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:validate": "prisma validate",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run db:validate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "admin:rotate-password": "tsx scripts/rotate-admin-password.ts",
    "normalize": "tsx scripts/normalize-pricelists.ts",
    "setup": "prisma db push && tsx prisma/seed.ts",
    "audit:production": "npm audit --omit=dev --audit-level=high"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "2.6.1",
    "clsx": "2.1.1",
    "jose": "6.2.3",
    "lucide-react": "1.25.0",
    "nanoid": "6.0.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "three": "0.185.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
