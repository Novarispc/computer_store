# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# --- Database (Neon Postgres) -------------------------------------------------
# From the Neon dashboard → Connection Details.
# DATABASE_URL: the POOLED string (host contains "-pooler"). Used at runtime.
# DIRECT_URL:   the DIRECT string (no "-pooler"). Used by prisma db push/migrate.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# --- Admin auth ---------------------------------------------------------------
ADMIN_PASSWORD="change-me-before-going-live"
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="a-64-char-hex-string"

# --- Image uploads (Vercel Blob) ---------------------------------------------
# Required in production so uploads don't hit Vercel's read-only filesystem.
# Auto-injected by Vercel when a Blob store is connected to the project.
# Omit locally to store uploads in public/ instead.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
