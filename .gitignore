# User-supplied source artwork (processed copies live in public/brand).
# Anchored with a leading slash: a bare `brand/` also matches
# src/components/brand/, and Tailwind v4's source detection honours .gitignore,
# so those components' classes would silently never be generated.
/brand/

# Admin-uploaded images (product photos + brand assets). The README stays.
public/uploads/
public/brand/*.png
public/brand/*.jpg
public/brand/*.webp
